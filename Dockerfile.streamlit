# ============================================================================
# Dockerfile for the Streamlit frontend.
#
# The UI is a thin HTTP client of the FastAPI backend, so this image only needs
# streamlit + httpx -> small and fast to build.
# ============================================================================
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Only the UI's runtime deps (avoids pulling torch into the frontend image).
RUN pip install --upgrade pip && pip install \
    streamlit==1.37.0 \
    httpx==0.27.0

COPY app/ ./app/

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -fsS http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "app/streamlit_app.py", \
     "--server.port=8501", "--server.address=0.0.0.0", \
     "--server.headless=true"]
