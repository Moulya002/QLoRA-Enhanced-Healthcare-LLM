# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.python-version

# ---- Environment / secrets ----
.env
.env.*
