# ============================================================================
# Environment configuration template.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#   cp .env.example .env
# ============================================================================

# ---- Hugging Face ----
# Required to download gated models (e.g. meta-llama/Llama-3.2-3B-Instruct).
# Create a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ---- Weights & Biases ----
# Experiment tracking. Get a key at https://wandb.ai/authorize
# Set WANDB_MODE=offline to log locally without an account, or "disabled" to skip.
WANDB_API_KEY=
WANDB_PROJECT=healthcare-qlora
WANDB_ENTITY=
WANDB_MODE=online

# ---- Model selection ----
# Base model to fine-tune. Options validated in this project:
#   - meta-llama/Llama-3.2-3B-Instruct   (gated, requires HF_TOKEN + license acceptance)
#   - microsoft/Phi-3-mini-4k-instruct   (open, no gating)
BASE_MODEL=microsoft/Phi-3-mini-4k-instruct

# Path where the trained LoRA adapter is written / read from.
ADAPTER_PATH=outputs/healthcare-qlora-adapter

# ---- Inference / serving ----
# The FastAPI backend reads these to load the model at startup.
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9

# ---- API + Streamlit wiring ----
API_HOST=0.0.0.0
API_PORT=8000
# URL the Streamlit frontend uses to reach the FastAPI backend.
# Inside docker-compose this is http://api:8000 ; locally it's http://localhost:8000
API_URL=http://localhost:8000

# ---- Misc ----
LOG_LEVEL=INFO
# Force CPU even if a GPU is available (useful for local smoke tests).
FORCE_CPU=false
